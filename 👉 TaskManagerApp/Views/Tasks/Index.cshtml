@model IEnumerable<TaskManagerApp.Models.TaskItem>

<div class="container mt-5">

    <!-- 🔥 Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📋 Task Dashboard</h2>
        <a class="btn btn-success shadow-sm" href="/Tasks/Create">
            <i class="bi bi-plus-circle"></i> Add Task
        </a>
    </div>

    <!-- 🔍 Search -->
    <form method="get" class="mb-4">
        <div class="input-group shadow-sm">
            <input type="text" name="search" class="form-control" placeholder="Search tasks..." />
            <button class="btn btn-dark">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </form>

    <!-- 📊 Stats -->
    <div class="row mb-4 text-center">
        <div class="col-md-4">
            <div class="card shadow p-3">
                <h6>Total Tasks</h6>
                <h3>@Model.Count()</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-3">
                <h6>Completed</h6>
                <h3 class="text-success">@Model.Count(t => t.IsCompleted)</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-3">
                <h6>Pending</h6>
                <h3 class="text-warning">@Model.Count(t => !t.IsCompleted)</h3>
            </div>
        </div>
    </div>

    <!-- 📋 Table -->
    <div class="card shadow-lg p-3">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Task</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">
                            No tasks found 😢
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsCompleted ? "table-success" : "")">

                            <td class="fw-semibold">
                                @item.Title
                            </td>

                            <td>
                                @if (item.IsCompleted)
                                {
                                    <span class="badge bg-success">
                                        ✔ Completed
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        ⏳ Pending
                                    </span>
                                }
                            </td>

                            <td class="text-end">
                                <a class="btn btn-sm btn-primary me-1"
                                   href="/Tasks/Edit/@item.Id">
                                    ✏ Edit
                                </a>

                                <a class="btn btn-sm btn-danger"
                                   href="/Tasks/Delete/@item.Id">
                                    🗑 Delete
                                </a>
                            </td>

                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

</div>